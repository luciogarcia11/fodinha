# Server
PORT=3001
NODE_ENV=development

# CORS — em produção troque pelo domínio do frontend
CORS_ORIGIN=http://localhost:3000

# PostgreSQL — string de conexão completa (takes precedence)
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://fodinha:changeme@localhost:5432/fodinha

# Variáveis individuais (usadas pelo docker-compose)
POSTGRES_USER=fodinha
POSTGRES_PASSWORD=changeme
POSTGRES_DB=fodinha

# Domínio público (usado pelo Caddy para SSL automático)
DOMAIN=seudominio.com

# pgAdmin (opcional, apenas com --profile db-admin)
PGADMIN_EMAIL=admin@fodinha.local
PGADMIN_PASSWORD=changeme
